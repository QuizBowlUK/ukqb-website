---
type Variant = "primary" | "secondary";
const { variant = "primary", ...props } = Astro.props as { variant?: Variant };
const variants: Record<Variant, string> = {
  primary: "bg-ukqb-red text-white hover:bg-red-800 active:scale-[0.98]",
  secondary:
    "bg-ukqb-red-hover text-black hover:bg-[#fdcece] active:scale-[0.98]",
};
---

<a
  class:list={[
    "inline-block cursor-pointer rounded-lg border-none px-5 py-2.5 text-center text-base font-semibold text-inherit no-underline transition-all duration-150 ease-in md:px-6",
    variants[variant],
  ]}
  {...props}
>
  <slot />
</a>
